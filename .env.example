# ---- AWS Bedrock (the "brain") ----
# Leave BEDROCK_MODEL_ID unset to run in DEMO MODE (built-in mock answers, no AWS needed).
# Set it to switch on real NL->SuiteQL via Bedrock.
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ---- NetSuite SuiteQL REST (the data) ----
# Leave NETSUITE_ACCOUNT unset to run in DEMO MODE (simulated rows).
# NETSUITE_ACCOUNT=1234567
# NETSUITE_ACCESS_TOKEN=        # OAuth 2.0 bearer token for the read-only role
